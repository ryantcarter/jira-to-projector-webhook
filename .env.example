# ClickUp (read side) — same workspace as the xml-to-clickup bridge.
CLICKUP_TOKEN=pk_xxx
CLICKUP_LIST_ID=901217277004

# Projector (write side).
PROJECTOR_API_URL=https://projector-nine.vercel.app/api/v1
PROJECTOR_API_KEY=pj_xxx
PROJECTOR_CLIENT_SLUG=evoke

# The external_source used for the idempotency key on tasks. Kept as "jira"
# so the one-time mirror and the live Jira→Projector service address the
# SAME Projector task (external_id = the Jira issue key, e.g. CRTR-286).
EXTERNAL_SOURCE=jira

# Import mirrored ClickUp comments as internal notes (staff-only) rather than
# client-visible comments. Safer default while parallel-running; flip to
# false for a fully client-visible mirror.
COMMENTS_INTERNAL=true

# Politeness delay between Projector writes (ms). ClickUp reads are throttled
# separately to stay under 100 req/min.
WRITE_DELAY_MS=120
